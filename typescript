              </CardContent>
            </Card>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
              <Card className="rounded-3xl border-0 shadow-sm bg-white/80">
                <CardHeader>
                  <CardTitle>Selected Stop</CardTitle>
